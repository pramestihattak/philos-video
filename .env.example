# Copy to .env and fill in values before running the server.

# Required — server refuses to start if JWT_SECRET equals the default.
JWT_SECRET=change-me-to-a-random-32+-char-string

# Required — Google OAuth credentials.
# Create at https://console.cloud.google.com/apis/credentials
# Add http://localhost:8080/auth/google/callback as an Authorized Redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Required — signs the user session cookie. Must be at least 32 characters.
SESSION_COOKIE_SECRET=change-me-to-a-random-32+-char-string

# Set to true in production (requires HTTPS).
SESSION_COOKIE_SECURE=false

# Optional — defaults shown.
PORT=8080
RTMP_PORT=1935
DATA_DIR=./data
WORKER_COUNT=2
JWT_EXPIRY=1h
DATABASE_URL=postgres://philos:philos@localhost:5433/philos_video?sslmode=disable

# Per-user upload quota in bytes. 0 = unlimited. Default: 10 GB.
DEFAULT_UPLOAD_QUOTA_BYTES=10737418240

# Logging — defaults shown.
LOG_LEVEL=info
LOG_FORMAT=text

GOLIVE_WHITELIST=
