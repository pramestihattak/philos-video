# Copy to .env and fill in values before running the server.

# Required — server refuses to start if JWT_SECRET equals the default.
JWT_SECRET=change-me-to-a-random-32+-char-string

# Optional — defaults shown.
PORT=8080
RTMP_PORT=1935
DATA_DIR=./data
WORKER_COUNT=2
JWT_EXPIRY=1h
DATABASE_URL=postgres://philos:philos@localhost:5433/philos_video?sslmode=disable

# Optional — if unset, /go-live and the stream-key API are publicly accessible.
GO_LIVE_PIN=
